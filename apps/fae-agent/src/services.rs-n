async fn get_agent_by_id(db_pool: &sqlx::SqlitePool, agent_id: &str) -> Result<crate::models::Agent, sqlx::Error> {
    let agent = sqlx::query_as!(
        crate::models::Agent,
        r#"
        SELECT 
            id as "id!",
            name as "name!",
            provider as "provider!",
            provider_config_id as "provider_config_id?",
            model as "model!",
            system_prompt as "system_prompt?",
            avatar_url as "avatar_url?",
            skills as "skills!: Vec<String>",
            created_at as "created_at!",
            updated_at as "updated_at!"
        FROM agents 
        WHERE id = ?
        "#,
        agent_id
    )
    .fetch_one(db_pool)
    .await?;
    
    Ok(agent)
}
        
        // Simulate tool calling based on skills (in real we'll actually connect agents to their specific tools)
        let tool_call_ids = ["search_tool", "calc_tool", "analysis_tool"];
        for tool_name in tool_call_ids.iter().take(2) {  // Just simulate a couple of tools
            let tool_call_id = format!("call_{}", uuid::Uuid::new_v4().to_string()[..8].to_string());
            
            yield Ok(Event::default()
                .event("data")
                .data(format!(
                    r#"{{"type":"tool-input-start","toolCallId":"{}","toolName":"{}"}}"#, 
                    tool_call_id, tool_name
                )));
            
            tokio::time::sleep(Duration::from_millis(300)).await;
            
            yield Ok(Event::default()
                .event("data")
                .data(format!(
                    r#"{{"type":"tool-call","toolCallId":"{}","toolName":"{}","input":{{"query":"{}","taskId":"analyze"}}}}"#, 
                    tool_call_id, tool_name, message.replace("\"", "")
                )));
            
            tokio::time::sleep(Duration::from_millis(500)).await;
            
            let esc_message = message.replace("\"", "'");
            yield Ok(Event::default()
                .event("data")
                .data(format!(
                    r#"{{"type":"tool-result","toolCallId":"{}","toolName":"{}","output":{{"status":"success","data":"Results for {} operation on {}", "query":"{}", "metadata":{{"execTime":123,"source":"internal"}}}}}}"#, 
                    tool_call_id, tool_name, tool_name, esc_message, esc_message
                )));
        }
        
        // Generate response segments based on the input message
        let response_segments = vec![
            format!("I have processed your request about ("),
            message.clone(),
            format!("). "),
            format!("Using available tools, "),
            format!("I have analyzed and synthesized the required information. "),
            "I hope this addresses your query. Is there anything else I can assist with?".to_string()
        ];
        
        for segment in response_segments {
            tokio::time::sleep(Duration::from_millis(100)).await;
            yield Ok(Event::default()
                .event("data")
                .data(format!(r#"{{"type":"chunk","content":"{}"}}"#, segment))); 
        }
    };
    
    Sse::new(stream).keep_alive(KeepAlive::default())
}

pub async fn chat_ws_handler(
    _state: State<crate::AppState>,
    ws: WebSocketUpgrade,
) -> Response {
    ws.on_upgrade(|websocket| async move {
        handle_socket(websocket).await;
    })
}

async fn handle_socket(mut websocket: axum::extract::ws::WebSocket) {
    while let Some(msg) = websocket.recv().await {
        if let Ok(axum::extract::ws::Message::Text(text)) = msg {
            // Process chat message
            let response = format!("Echo via WS: {}", text);
            
            if websocket.send(axum::extract::ws::Message::Text(response)).await.is_err() {
                // Client disconnected
                break;
            }
        } else if msg.is_err() {
            // Error occurred
            break;
        }
    }
}

