{
  "name": "fae",
  "private": true,
  "version": "0.1.0",
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev:agent\" \"npm run dev:web\"",
    "dev:agent": "cd apps/fae-agent && cargo run",
    "dev:web": "bun run --cwd apps/web dev",
    "test": "cd apps/fae-agent && cargo test",
    "build:agent": "cd apps/fae-agent && cargo build --release",
    "build:web": "bun run --cwd apps/web build",
    "typecheck": "bun run --cwd apps/web typecheck"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
